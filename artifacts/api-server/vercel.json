{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/api-server/dist",
  "functions": {
    "artifacts/api-server/dist/vercel-entry.mjs": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/artifacts/api-server/dist/vercel-entry.mjs" }
  ]
}
